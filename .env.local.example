# Supabase (https://supabase.com で無料プロジェクト作成 → Settings > API Keys)
# 値の行にインラインコメントを付けないこと(パーサが値の一部として取り込むトラップ防止)

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Publishable key (旧 anon key)。ブラウザ公開可、RLS が守る
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Secret key (旧 service_role)。絶対にクライアントに出さない、API ルート/サーバー専用
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxx

# IP ハッシュ用ソルト(任意、未設定でも動く)
IP_HASH_SALT=replace-me-with-random-string

# /admin(運営専用モデレーション画面)の認証。サーバー専用。絶対に NEXT_PUBLIC を付けない。
# ADMIN_PASSWORD: 共有パスワード。constant-time 比較される。十分に長くランダムに。
# ADMIN_SESSION_SECRET: 署名 cookie(HMAC-SHA256)の鍵。ローテーションすると全セッション一括失効。
# 両方未設定だと /admin はログイン不能(フェイルクローズ=誰も入れない)。
ADMIN_PASSWORD=replace-me-with-a-long-random-password
ADMIN_SESSION_SECRET=replace-me-with-a-long-random-secret
